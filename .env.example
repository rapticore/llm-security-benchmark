# Enhanced Multi-LLM Security Benchmark Environment Variables
# Copy this file to .env and fill in your API keys
#
# ⚠️  IMPORTANT: Never commit the actual .env file with real API keys to version control!
# ⚠️  Add .env to your .gitignore file to prevent accidental commits

# ===================================================================
# CORE MODEL PROVIDERS
# ===================================================================

# OpenAI API Key (for GPT models: gpt-5, gpt-5-mini, gpt-4o, gpt-4o-mini)
# Get your key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your_openai_api_key_here

# Anthropic API Key (for Claude models: claude-opus-4, claude-sonnet-4)
# Get your key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-api03-your_anthropic_api_key_here

# Google AI API Key (for Gemini models: gemini-2.5-flash, gemini-2.5-flash-lite, gemini-2.0-flash, gemini-2.0-flash-lite)
# Get your key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIzaSy-your_google_ai_api_key_here

# ===================================================================
# NEW MODEL PROVIDERS (Added in v2.0+)
# ===================================================================

# X.AI API Key (for Grok models: grok-4, grok-3, grok-3-mini, grok-code-fast-1)
# Get your key from: https://console.x.ai/
XAI_API_KEY=xai-your_xai_api_key_here

# DeepSeek API Key (for DeepSeek models: deepseek-v3, deepseek-chat, deepseek-coder)
# Get your key from: https://platform.deepseek.com/
DEEPSEEK_API_KEY=sk-your_deepseek_api_key_here

# Llama API Key (for Meta Llama models via API providers)
# Supported providers: Anyscale, Fireworks AI, or other OpenAI-compatible providers
LLAMA_API_KEY=your_llama_provider_api_key_here

# ===================================================================
# OPTIONAL CONFIGURATION
# ===================================================================

# Llama Base URL (optional - configure based on your provider)
# Anyscale: https://api.endpoints.anyscale.com/v1
# Fireworks AI: https://api.fireworks.ai/inference/v1
# Default: OpenAI-compatible endpoint
LLAMA_BASE_URL=https://api.openai.com/v1

# Ollama Base URL (optional - defaults to localhost)
# Only change if running Ollama on a different host/port
OLLAMA_BASE_URL=http://localhost:11434

# ===================================================================
# PERFORMANCE TUNING (Optional)
# ===================================================================

# Default timeout for API requests (seconds)
# DEFAULT_TIMEOUT=10

# Maximum concurrent workers for parallel execution
# DEFAULT_MAX_WORKERS=4

# Enable debug logging (true/false)
# DEBUG_MODE=false

# ===================================================================
# COST MANAGEMENT
# ===================================================================

# Set to true to enable cost warnings for expensive operations
# COST_WARNINGS=true

# Maximum cost per test run (USD) - benchmark will warn if exceeded
# MAX_COST_PER_RUN=10.00

# ===================================================================
# EXAMPLE USAGE
# ===================================================================
#
# Quick Start (minimal setup):
# 1. Set OPENAI_API_KEY for basic GPT model testing
# 2. Run: python3 enhanced_multi_llm_benchmark.py --suite fast --models gpt-4o-mini
#
# Full Setup (all providers):
# 1. Configure all API keys above
# 2. Run: python3 enhanced_multi_llm_benchmark.py --suite comprehensive --models premium
#
# Local Testing (zero cost):
# 1. Install Ollama: https://ollama.com/
# 2. Run: ollama pull llama3.3
# 3. Run: python3 enhanced_multi_llm_benchmark.py --suite basic --models ollama/llama3.3
#
# ===================================================================